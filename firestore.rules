rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && validProfile(request.resource.data);

      match /expenses/{expenseId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null && request.auth.uid == uid
          && validExpense(request.resource.data);
      }
    }
  }

  function validProfile(data) {
    return data.displayName is string
      && data.displayName.size() <= 100
      && data.email is string
      && data.email.size() <= 200
      && data.customCategories is list
      && data.customCategories.size() <= 50;
  }

  function validExpense(data) {
    return data.keys().hasOnly(['date', 'amount', 'category', 'description', 'createdAt'])
      && data.amount is number
      && data.amount > 0
      && data.amount < 1000000000
      && data.date is string
      && data.date.size() == 10
      && data.category is string
      && data.category.size() > 0
      && data.category.size() <= 50
      && data.description is string
      && data.description.size() <= 500;
  }
}
